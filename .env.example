# ===== API Keys =====
DASHSCOPE_API_KEY = 
HF_TOKEN= 
WANDB_API_KEY= 

# ===== Experiment Tracking =====
WANDB_PROJECT= PaMM
WANDB_ENTITY=
WANDB_MODE= online

# ===== Paths =====
DATA_DIR=./datasets
OUTPUT_DIR=./outputs
CACHE_DIR=./cache
CHECKPOINT_DIR=./checkpoints
LOG_DIR=./logs

# ===== Runtime =====
SEED=42
DEVICE=cuda
CUDA_VISIBLE_DEVICES=0
TOKENIZERS_PARALLELISM=false

# ===== Training / Inference =====
BATCH_SIZE=4
MAX_TOKENS=2048
TEMPERATURE=0.0
TOP_P=1.0

# ===== Notification (ntfy) =====
NTFY_TOPIC=mysecretchannel
NTFY_SERVER=https://ntfy.sh
NTFY_PRIORITY=default

# ===== Debug =====
DEBUG=false
LOG_LEVEL=INFO
